---
import { getCollection } from "astro:content";
import Body from "../components/Body.astro";
import BookCover from "../components/BookCover.astro";

const books = (await getCollection("books")).sort((a, b) =>
	a.data.title.localeCompare(b.data.title),
);

const STATUS_LABELS = {
	read: "Read",
	reading: "Reading",
	"to-read": "Will read",
} as const;

const filters = [
	{ value: "read", label: "Read" },
	{ value: "reading", label: "Reading" },
	{ value: "to-read", label: "Will read" },
	{ value: "all", label: "All" },
] as const;

const counts = {
	read: books.filter((book) => book.data.status === "read").length,
	reading: books.filter((book) => book.data.status === "reading").length,
	"to-read": books.filter((book) => book.data.status === "to-read").length,
	all: books.length,
};
---

<Body title="Books" description="What I've read, what I'm reading, and what's next." toc={false}>
  <nav slot="rail" class="controls">
    <p class="controls__kicker">Shelf</p>
    <div class="controls__group" data-filters>
      {
        filters.map((filter) => (
          <button type="button" data-filter={filter.value}>
            {filter.label}
            <span>{counts[filter.value]}</span>
          </button>
        ))
      }
    </div>

    <p class="controls__kicker">Sort</p>
    <div class="controls__group" data-sorts>
      <button type="button" data-sort="asc">A–Z</button>
      <button type="button" data-sort="desc">Z–A</button>
    </div>
  </nav>

  <h1 class="page-title">What I've read, what I'm reading, and what's next.</h1>

  <ul class="shelf" data-shelf>
    {
      books.map((book) => (
        <li
          data-status={book.data.status}
          data-title={book.data.title.toLowerCase()}
          data-id={book.id}
        >
          <BookCover cover={book.data.cover} title={book.data.title} author={book.data.author} />
          <p class="shelf__status">{STATUS_LABELS[book.data.status]}</p>
          <p class="shelf__title">{book.data.title}</p>
          <p class="shelf__author">{book.data.author}</p>
          {book.data.rating && (
            <p class="shelf__rating">
              {book.data.rating}<span>/5</span>
            </p>
          )}
        </li>
      ))
    }
  </ul>

  <p class="shelf__empty" data-empty hidden>Nothing on this shelf yet.</p>
</Body>

<script>
	// No framework for this: it's two lists and a sort. The shelf is rendered
	// in full at build time and filtered in place.
	const shelf = document.querySelector<HTMLElement>("[data-shelf]");
	const empty = document.querySelector<HTMLElement>("[data-empty]");
	if (shelf && empty) {
		const books = Array.from(shelf.children) as HTMLElement[];

		const setPressed = (container: string, attribute: string, value: string) => {
			for (const button of document.querySelectorAll<HTMLElement>(
				`[${container}] button`,
			)) {
				button.setAttribute(
					"aria-pressed",
					String(button.dataset[attribute] === value),
				);
			}
		};

		const apply = (status: string, direction: string) => {
			let visible = 0;
			for (const book of books) {
				const shown = status === "all" || book.dataset.status === status;
				book.hidden = !shown;
				if (shown) visible++;
			}
			empty.hidden = visible > 0;

			const sorted = [...books].sort((a, b) =>
				(a.dataset.title ?? "").localeCompare(b.dataset.title ?? ""),
			);
			if (direction === "desc") sorted.reverse();
			for (const book of sorted) shelf.appendChild(book);

			setPressed("data-filters", "filter", status);
			setPressed("data-sorts", "sort", direction);
		};

		/* Filtering and sorting move every book at once, and a shelf that
		   teleports is a shelf you lose your place in. The DOM work is
		   unchanged — the browser just tweens each book from where it was to
		   where it lands. Not everyone has the API; they get the jump. */
		type ViewTransitionDocument = Document & {
			startViewTransition?: (callback: () => void) => unknown;
		};
		const view = document as ViewTransitionDocument;

		/* Naming a book lifts it out of the page snapshot into one of its own,
		   and each one costs: naming all 250 spends ~700ms capturing before
		   anything moves, against ~250ms for a dozen. Nearly all of that is
		   spent on books scrolled out of sight — which is wasted twice over,
		   since you can't lose track of a book you can't see. So only the ones
		   on screen are worth animating. */
		const nameOnscreen = () => {
			const margin = 200;
			for (const book of books) {
				const box = book.getBoundingClientRect();
				const onscreen =
					!book.hidden &&
					box.bottom > -margin &&
					box.top < window.innerHeight + margin;
				book.style.viewTransitionName = onscreen
					? `book-${book.dataset.id}`
					: "none";
			}
		};

		const run = (status: string, direction: string) => {
			if (!view.startViewTransition) {
				apply(status, direction);
				return;
			}
			nameOnscreen();
			view.startViewTransition(() => apply(status, direction));
		};

		// Defaults to `read`: the shelf is 78% aspiration, so opening on
		// everything would bury what's actually been read.
		let status = "read";
		let direction = "asc";

		for (const button of document.querySelectorAll<HTMLElement>("[data-filter]")) {
			button.addEventListener("click", () => {
				status = button.dataset.filter ?? "read";
				run(status, direction);
			});
		}
		for (const button of document.querySelectorAll<HTMLElement>("[data-sort]")) {
			button.addEventListener("click", () => {
				direction = button.dataset.sort ?? "asc";
				run(status, direction);
			});
		}

		// The first pass is the page arriving, not a change to react to.
		apply(status, direction);
	}
</script>

{/* The view-transition pseudos hang off the document root, not off anything
    in this component, so scoped styles would never reach them. */}
<style is:global>
	/* The shelf is the only thing on the page that changes, so the full-page
	   cross-fade the root snapshot gives us by default is just a flash across
	   the rail and the title. Opt the root out and let the books carry it. */
	::view-transition-image-pair(root) {
		isolation: auto;
	}

	::view-transition-old(root),
	::view-transition-new(root) {
		animation: none;
		mix-blend-mode: normal;
		display: block;
	}

	/* Movement, so --dur-move rather than --dur. Where the wildcard isn't
	   understood the books still animate, just on the UA's own default. */
	::view-transition-group(*) {
		animation-duration: var(--dur-move);
		animation-timing-function: var(--ease);
	}
</style>

<style>
	.page-title {
		font: var(--text-display);
		letter-spacing: var(--track-tight);
		color: var(--text-heading);
		max-width: 18ch;
		margin: 0 0 40px;
	}

	.controls__kicker {
		font: var(--text-kicker);
		letter-spacing: var(--track-kicker);
		text-transform: uppercase;
		color: var(--text-meta);
		margin: 0 0 10px;
	}

	.controls__group {
		display: flex;
		flex-direction: column;
		border-top: var(--border-strong-w) solid var(--border-strong);
		margin-bottom: 28px;
	}

	.controls__group button {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 9px 0;
		border: none;
		border-bottom: var(--border-hairline-w) solid var(--border-hairline);
		background: none;
		cursor: pointer;
		font: var(--text-body);
		color: var(--text-heading);
		text-align: left;
	}

	.controls__group button span {
		font: var(--text-mono-sm);
		color: var(--text-meta);
	}

	.controls__group button:hover {
		color: var(--link-hover);
	}

	.controls__group button[aria-pressed="true"] {
		font-weight: var(--weight-semibold);
		color: var(--link);
	}

	.controls__group button[aria-pressed="true"] span {
		color: var(--accent-fg);
	}

	.shelf {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 32px 20px;
	}

	.shelf__status {
		font: var(--text-mono-sm);
		text-transform: uppercase;
		color: var(--text-meta);
		margin: 10px 0 0;
	}

	.shelf__title {
		font: var(--text-small);
		font-weight: var(--weight-semibold);
		color: var(--text-heading);
		margin: 4px 0 0;
	}

	.shelf__author {
		font: var(--text-small);
		color: var(--text-muted);
		margin: 2px 0 0;
	}

	/* Ratings are mono numerals, not stars — a second gold accent would break
	   the one-accent rule, and only a handful of books are rated anyway. */
	.shelf__rating {
		font: var(--text-mono-sm);
		color: var(--accent-fg);
		margin: 4px 0 0;
	}

	.shelf__rating span {
		color: var(--text-meta);
	}

	.shelf__empty {
		font: var(--text-body);
		color: var(--text-muted);
	}

	@media (max-width: 900px) {
		.page-title {
			font: var(--text-h1);
			max-width: none;
		}

		.shelf {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 640px) {
		.shelf {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
