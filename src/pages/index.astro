---
import { getCollection } from "astro:content";
import Body from "../components/Body.astro";
import Books from "../components/Books.astro";
import Button from "../components/Button.astro";
import Kicker from "../components/Kicker.astro";
import ListRow from "../components/ListRow.astro";
import Pipeline from "../components/Pipeline.astro";
import Projects from "../components/Projects.astro";
import SectionHeader from "../components/SectionHeader.astro";
import WorkExperience from "../components/WorkExperience.astro";
import { filterPosts, sortAsc } from "../utils";

const posts = await getCollection("blog", filterPosts);
const recentPosts = posts.sort(sortAsc).slice(0, 5);

const coreFocus = [
	{ title: "Termzig", description: "Building a terminal emulator in Zig." },
	{
		title: "OpenGL & Graphics",
		description: "Exploring WebGL and graphics programming.",
	},
	{
		title: "Data Structures & Algorithms",
		description: "Deepening fundamentals in algorithms and problem solving.",
	},
];

const comingUp = [
	"C/C++ & Systems",
	"Assembly",
	"Operating Systems & Embedded",
];
---

<Body title="Oscar te Giffel" description="Finding meaning in code, life and humans" toc={false}>
  <section class="section">
    <SectionHeader number="01" label="Introduction" />
    <p class="lead">
      Hi there! I'm Oscar, a <strong>Senior Fullstack Engineer</strong> working as a <strong>freelancer</strong>.
      I specialize in <strong>fullstack development</strong> with <strong>React/Kotlin</strong> and <strong>software architecture</strong>.
      I find the best technical fit for each problem and build scalable solutions that deliver great user experience and developer experience.
    </p>
  </section>

  <WorkExperience number="02" />

  <Projects number="03" />

  <section class="section">
    <SectionHeader number="04" label="Roadmap" />

    <p class="roadmap__intro">currently learning / building</p>

    {
      coreFocus.map((item, index) => (
        <ListRow
          title={item.title}
          subtitle={item.description}
          lastBorder={index === coreFocus.length - 1}
        />
      ))
    }

    <div class="roadmap__next">
      <Kicker>Coming up</Kicker>
      <div class="roadmap__pipeline">
        <Pipeline steps={comingUp} activeIndex={0} />
      </div>
    </div>

    <div class="roadmap__action">
      <Button href="https://github.com/oscarteg" arrow>Follow the progress on GitHub</Button>
    </div>
  </section>

  <Books number="05" />

  <section class="section">
    <SectionHeader number="06" label="Writing" action={{ label: "All ↗", href: "/blog" }} />
    {
      recentPosts.map((post, index) => (
        <ListRow
          title={post.data.title}
          subtitle={post.data.description}
          href={`/blog/${post.id}`}
          lastBorder={index === recentPosts.length - 1}
        />
      ))
    }
  </section>
</Body>

<style>
	.section {
		margin-bottom: 52px;
	}

	.section:last-child {
		margin-bottom: 0;
	}

	.lead {
		font: var(--text-lead);
		letter-spacing: -0.015em;
		color: var(--text-heading);
		max-width: var(--measure);
	}

	.lead strong {
		font-weight: var(--weight-semibold);
	}

	.roadmap__intro {
		font: var(--text-small);
		color: var(--text-muted);
		margin-bottom: 20px;
	}

	.roadmap__next {
		margin-top: 32px;
	}

	.roadmap__pipeline {
		margin-top: 12px;
	}

	.roadmap__action {
		margin-top: 32px;
	}
</style>
