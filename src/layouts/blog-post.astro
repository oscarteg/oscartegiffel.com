---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import DraftMarker from "../components/DraftMarker.astro";
import Kicker from "../components/Kicker.astro";
import type { Post } from "../models";
import { filterPosts, postVisibility } from "../utils";
import DefaultLayout from "./default.astro";

type Props = {
	post: Post;
	lastModified: Date;
	headings?: { depth: number; slug: string; text: string }[];
};

const { post, headings = [] } = Astro.props;

const {
	title,
	description = "",
	cover,
	publishDate,
	toc = false,
	resources = [],
	showResources = true,
	series,
} = post.data;

const visibleResources = showResources ? resources : [];

const seriesPosts = series
	? (await getCollection("blog", filterPosts))
			.filter((entry) => entry.data.series === series)
			.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
	: [];

const currentPart = seriesPosts.findIndex((entry) => entry.id === post.id) + 1;

const visibility = postVisibility(post);
---

<DefaultLayout title={title} description={description} headings={headings} post={post} frontmatter={{ title, description, toc }}>
  <div class="post__meta">
    {publishDate && <Kicker>{dayjs(publishDate).format("MMM DD, YYYY")}</Kicker>}
    <DraftMarker visibility={visibility} />
  </div>

  {
    seriesPosts.length > 0 && (
      <nav class="not-prose series">
        <p class="series__label">
          {series} · Part {currentPart} of {seriesPosts.length}
        </p>
        <ol class="series__list">
          {seriesPosts.map((entry, index) => (
            <li>
              <span class="series__index">{index + 1}</span>
              {entry.id === post.id ? (
                <span class="series__current">{entry.data.title}</span>
              ) : (
                <a href={`/blog/${entry.id}`}>{entry.data.title}</a>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )
  }

  {
    cover && (
      <div class="not-prose post__cover">
        <Image src={cover} alt="cover" />
      </div>
    )
  }

  <slot />

  {
    visibleResources.length > 0 && (
      <section class="not-prose resources">
        <p class="resources__label">Resources</p>
        <ul>
          {visibleResources.map((resource) => (
            <li>
              <span class="resources__marker" aria-hidden="true" />
              <a href={resource.url} target="_blank" rel="noopener noreferrer">
                {resource.title ?? new URL(resource.url).hostname.replace(/^www\./, "")}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <aside class="not-prose colophon">
    <p class="colophon__label">How it was written</p>
    <p class="colophon__body">
      Most of the content was written by my own hand, but I did leverage AI for
      many things, such as polishing, structuring, research and review.
    </p>
  </aside>
</DefaultLayout>

<style>
	.post__meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 10px 16px;
		margin-bottom: 32px;
	}

	/* Raised paper + a hairline, with the accent carried by a single
	   left rule — elevation without shadow. */
	.series,
	.colophon {
		width: 100%;
		background: var(--surface-card);
		border: var(--border-hairline-w) solid var(--border-hairline);
		border-left: var(--border-strong-w) solid var(--accent);
		border-radius: var(--radius);
		padding: 16px 20px;
	}

	.series {
		margin-bottom: 40px;
	}

	.colophon {
		margin-top: 32px;
	}

	.series__label,
	.colophon__label {
		font: var(--text-kicker);
		letter-spacing: var(--track-kicker);
		text-transform: uppercase;
		color: var(--accent-fg);
		margin: 0 0 12px;
	}

	.colophon__body {
		font: var(--text-small);
		color: var(--text-muted);
		margin: 0;
	}

	.series__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.series__list li {
		display: flex;
		align-items: baseline;
		gap: 12px;
		font: var(--text-small);
	}

	.series__index {
		font: var(--text-mono-sm);
		color: var(--text-meta);
		flex-shrink: 0;
	}

	.series__current {
		font-weight: var(--weight-semibold);
	}

	.series__list a {
		color: var(--text-muted);
		text-decoration: none;
	}

	.series__list a:hover {
		color: var(--link-hover);
	}

	/* Images sit in hairline frames; never full-bleed, never rounded. */
	.post__cover {
		border: var(--border-hairline-w) solid var(--border-hairline);
		border-radius: var(--radius);
		margin-bottom: 32px;
	}

	.post__cover :global(img) {
		display: block;
		width: 100%;
		height: 12rem;
		object-fit: cover;
	}

	.resources {
		width: 100%;
		margin-top: 64px;
		border-top: var(--border-strong-w) solid var(--border-strong);
		padding-top: 16px;
	}

	.resources__label {
		font: var(--text-kicker);
		letter-spacing: var(--track-kicker);
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 14px;
	}

	.resources ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.resources li {
		display: flex;
		align-items: baseline;
		gap: 12px;
	}

	.resources__marker {
		width: var(--marker-size);
		height: var(--marker-size);
		background: var(--marker);
		flex-shrink: 0;
	}

	.resources a {
		font: var(--text-small);
		color: var(--text-muted);
		text-decoration: none;
		word-break: break-word;
	}

	.resources a:hover {
		color: var(--link-hover);
	}
</style>
