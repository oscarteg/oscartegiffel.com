---
import { siteMetadata } from "../config";
import ListRow from "./ListRow.astro";
import SectionHeader from "./SectionHeader.astro";

export type Props = {
	number: string;
};

const { number } = Astro.props;
const entries = siteMetadata.content.workExperience;
---

<section class="section">
  <SectionHeader number={number} label="Experience" />

  {
    entries.map((entry, index) => (
      <ListRow
        left={entry.period}
        title={`${entry.role} · ${entry.company}`}
        meta={entry.stack.join(" · ")}
        lastBorder={index === entries.length - 1}
      >
        {entry.via && <span class="work__via">{entry.via}</span>}
        <p class="work__description" set:html={entry.description} />
      </ListRow>
    ))
  }
</section>

<style>
	.section {
		margin-bottom: 52px;
	}

	.work__via {
		display: block;
		font: var(--text-mono-sm);
		color: var(--text-meta);
		margin-top: 3px;
	}

	.work__description {
		font: var(--text-small);
		color: var(--ink-soft);
		margin-top: 8px;
		max-width: var(--measure);
	}

	/* The descriptions carry <strong> from config. The system has no
	   underline ornament, so emphasis is weight alone. */
	.work__description :global(strong) {
		font-weight: var(--weight-semibold);
		color: var(--text-heading);
	}
</style>
