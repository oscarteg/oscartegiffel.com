---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

/**
 * A jacket in a hairline frame. Roughly a third of the shelf has no cover —
 * no ISBN, or none Open Library knows about — so the fallback is a real part
 * of the design rather than an edge case: the title set in the grotesk on
 * raised paper.
 */
export type Props = {
	cover?: ImageMetadata | undefined;
	title: string;
	author: string;
};

const { cover, title, author } = Astro.props;
---

<div class="cover">
  {
    cover ? (
      <Image src={cover} alt={`${title} by ${author}`} widths={[160, 320]} loading="lazy" />
    ) : (
      <div class="cover__fallback">
        <span class="cover__fallback-title">{title}</span>
      </div>
    )
  }
</div>

<style>
	.cover {
		aspect-ratio: 2 / 3;
		border: var(--border-hairline-w) solid var(--border-hairline);
		border-radius: var(--radius);
		background: var(--surface-card);
		overflow: hidden;
	}

	.cover :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.cover__fallback {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: flex-end;
		padding: 12px;
	}

	.cover__fallback-title {
		font: var(--text-small);
		font-weight: var(--weight-semibold);
		line-height: 1.25;
		letter-spacing: var(--track-heading);
		color: var(--text-muted);
		/* Long titles would otherwise spill out of the jacket. */
		display: -webkit-box;
		-webkit-line-clamp: 6;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
