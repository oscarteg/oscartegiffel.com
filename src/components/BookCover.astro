---
import { getImage, Image } from "astro:assets";
import type { ImageMetadata } from "astro";

/**
 * A jacket in a hairline frame, turned just far enough to show its spine.
 * A tenth of the shelf has no cover — no ISBN, or none Open Library knows
 * about — so the fallback is a real part of the design rather than an edge
 * case: the title set in the grotesk on raised paper.
 */
export type Props = {
	cover?: ImageMetadata | undefined;
	title: string;
	author: string;
};

const { cover, title, author } = Astro.props;

/* The spine wears the jacket rather than a second asset: blown up to 9x its
   own width and anchored left, only the leftmost sliver of the cover shows,
   stretched across the face. CSS needs a URL and `cover` is ImageMetadata,
   so resolve one instead of reaching for the unprocessed `cover.src`. */
const spine = cover ? await getImage({ src: cover, width: 320 }) : undefined;
---

<div class="cover">
  <div class="cover__book">
    <div class="cover__face">
      {
        cover ? (
          <Image src={cover} alt={`${title} by ${author}`} widths={[160, 320]} loading="lazy" />
        ) : (
          <div class="cover__fallback">
            <span class="cover__fallback-title">{title}</span>
          </div>
        )
      }
    </div>
    <div
      class:list={["cover__spine", !spine && "cover__spine--blank"]}
      style={spine && `background-image: url(${spine.src})`}
    >
    </div>
  </div>
</div>

<style>
	/* The one place the system draws an object instead of a surface. It stays
	   honest to the rest of it: no contact shadow, no gloss, square corners —
	   the turn and the spine do the work. */
	.cover {
		aspect-ratio: 2 / 3;
		perspective: 1200px;
		perspective-origin: 50% 40%;
	}

	/* Positive rotateY brings the LEFT edge forward, which is the edge a book
	   is bound on. Turning the other way would hide the spine behind the
	   jacket and show the page block instead. */
	.cover__book {
		position: relative;
		width: 100%;
		height: 100%;
		transform-style: preserve-3d;
		transform: rotateY(14deg);
	}

	.cover__face {
		position: absolute;
		inset: 0;
		border: var(--border-hairline-w) solid var(--border-hairline);
		border-radius: var(--radius);
		background: var(--surface-card);
		overflow: hidden;
		transform: translateZ(var(--book-depth));
	}

	.cover__face :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Anchored at the jacket's left edge and swung back on it, so the face
	   depends only on --book-depth. The reference this is adapted from pushes
	   each face out by half the book's width, which needs the width to be a
	   known pixel value; this shelf is a fluid grid, so there isn't one. */
	.cover__spine {
		position: absolute;
		top: 0;
		left: 0;
		width: var(--book-depth);
		height: 100%;
		background-size: 900% 100%;
		background-position: 0;
		/* A face turned away from the light. */
		filter: brightness(0.62) saturate(1.15);
		transform-origin: left center;
		transform: rotateY(-90deg);
	}

	/* No jacket to take a colour from, so the fill has to carry it — and it
	   can't go through the dimming above. Darkening a flat paper tone reads
	   as a spine on light paper but sinks it into the page on dark, where the
	   whole ramp has already inverted. The token flips instead. */
	.cover__spine--blank {
		background-color: var(--spine-blank);
		filter: none;
	}

	.cover__fallback {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: flex-end;
		padding: 12px;
	}

	.cover__fallback-title {
		font: var(--text-small);
		font-weight: var(--weight-semibold);
		line-height: 1.25;
		letter-spacing: var(--track-heading);
		color: var(--text-muted);
		/* Long titles would otherwise spill out of the jacket. */
		display: -webkit-box;
		-webkit-line-clamp: 6;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
