---
import { siteMetadata } from "../config";
import Card from "./Card.astro";
import SectionHeader from "./SectionHeader.astro";

export type Props = {
	number: string;
};

const { number } = Astro.props;
const projects = siteMetadata.content.projects;
---

<section class="section">
  <SectionHeader number={number} label="Selected work" />

  <div class="projects">
    {
      projects.map((project) => (
        <Card href={project.url}>
          <div class="project__head">
            <span class="project__name">{project.name}</span>
            <span class="project__status">{project.status} ↗</span>
          </div>

          {/* Type-and-rule first: the shot sits in a hairline frame, square
              and unshadowed, rather than a floating rounded card. */}
          <div class="project__frame">
            <img
              src={project.image}
              alt={`${project.name} preview`}
              loading="lazy"
              decoding="async"
            />
          </div>

          <p class="project__description" set:html={project.description} />
          <div class="project__stack">{project.stack.join(" · ")}</div>
        </Card>
      ))
    }
  </div>
</section>

<style>
	.section {
		margin-bottom: 52px;
	}

	.projects {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	.project__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
	}

	.project__name {
		font: var(--text-h3);
		font-weight: var(--weight-semibold);
	}

	.project__status {
		font: var(--text-mono-sm);
		color: var(--accent);
		text-transform: uppercase;
		white-space: nowrap;
	}

	.project__frame {
		margin: 14px 0;
		border: var(--border-hairline-w) solid var(--border-hairline);
		border-radius: var(--radius);
		background: var(--surface-page);
	}

	.project__frame img {
		display: block;
		width: 100%;
		height: auto;
	}

	.project__description {
		font: var(--text-body);
		color: var(--ink-soft);
		margin-bottom: 14px;
	}

	.project__description :global(strong) {
		font-weight: var(--weight-semibold);
		color: var(--text-heading);
	}

	.project__stack {
		font: var(--text-mono-sm);
		color: var(--text-meta);
		text-transform: uppercase;
	}

	@media (max-width: 900px) {
		.projects {
			grid-template-columns: 1fr;
		}
	}
</style>
