---
import { uses } from "../config";
---

<div class="not-prose w-full space-y-14 mt-12">
	{uses.map((category) => (
		<section class="grid grid-cols-1 gap-x-8 gap-y-6 border-t border-black/5 dark:border-white/10 pt-8 md:grid-cols-[7rem_1fr]">
			<h2 class="text-[11px] uppercase tracking-[0.2em] text-text-muted font-medium md:pt-1">
				{category.title}
			</h2>
			<div class="space-y-6">
				{category.items.map((item) => (
					<div>
						<h3 class="font-semibold leading-snug">
							{item.href ? (
								<a
									href={item.href}
									target="_blank"
									rel="noopener noreferrer"
									class="hover:text-primary transition-colors"
								>
									{item.name}
								</a>
							) : (
								item.name
							)}
						</h3>
						{item.description && (
							<p class="text-text-muted text-sm leading-relaxed mt-1">
								{item.description}
							</p>
						)}
					</div>
				))}
			</div>
		</section>
	))}
</div>
